{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 4: SHAP Explainability Analysis\n",
    "## When Do Models Fail? Discovering Hidden Failure Patterns\n",
    "\n",
    "This notebook covers:\n",
    "1. Computing SHAP values for trained models\n",
    "2. Comparing feature importance in normal vs failure cases\n",
    "3. SHAP summary and dependence plots\n",
    "4. Understanding why models fail in specific situations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import shap\n",
    "from src.data_ingestion import load_config, download_zone_lookup\n",
    "from src.models import run_all_models\n",
    "from src.failure_analysis import run_failure_analysis\n",
    "from src.explainability import (\n",
    "    compute_shap_values, analyze_failure_shap,\n",
    "    generate_shap_plots, run_explainability\n",
    ")\n",
    "\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "%matplotlib inline\n",
    "\n",
    "config = load_config('../configs/config.yaml')\n",
    "zone_lookup = download_zone_lookup(config)\n",
    "print('Ready.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Train Models & Run Failure Analysis\n",
    "Reuse from previous notebooks or retrain."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = run_all_models(config)\n",
    "analysis = run_failure_analysis(results, config, zone_lookup)\n",
    "print('Models trained and failure analysis complete.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Run SHAP Explainability"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "shap_results = run_explainability(results, analysis, config)\n",
    "print(f'SHAP computed for: {list(shap_results.keys())}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. SHAP Summary Plots\n",
    "### Overall Feature Importance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# SHAP summary for Random Forest (typically most informative)\n",
    "if 'random_forest' in shap_results:\n",
    "    sr = shap_results['random_forest']\n",
    "    feature_cols = results['feature_cols']\n",
    "    X_df = pd.DataFrame(sr['X_sample'], columns=feature_cols)\n",
    "    \n",
    "    print('Random Forest - SHAP Summary (All Predictions):')\n",
    "    shap.summary_plot(sr['shap_values'], X_df, max_display=20, show=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# SHAP summary for failure cases only\n",
    "if 'random_forest' in shap_results:\n",
    "    sr = shap_results['random_forest']\n",
    "    failure_mask = sr['is_failure']\n",
    "    \n",
    "    if failure_mask.sum() > 10:\n",
    "        print(f'Random Forest - SHAP Summary (Failure Cases Only, n={failure_mask.sum()}):')\n",
    "        X_failures = X_df.iloc[np.where(failure_mask)[0]]\n",
    "        shap.summary_plot(sr['shap_values'][failure_mask], X_failures, max_display=20, show=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Feature Importance: Normal vs Failure"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare feature importance between normal and failure predictions\n",
    "for model_name, sr in shap_results.items():\n",
    "    comparison = sr['comparison']\n",
    "    \n",
    "    print(f'\\n{model_name.replace(\"_\", \" \").title()} — Top 15 Features:')\n",
    "    print(comparison.head(15).to_string())\n",
    "    \n",
    "    # Bar chart\n",
    "    top_15 = comparison.head(15)\n",
    "    \n",
    "    fig, ax = plt.subplots(figsize=(12, 8))\n",
    "    x = np.arange(len(top_15))\n",
    "    width = 0.35\n",
    "    \n",
    "    ax.barh(x + width/2, top_15['normal_mean_shap'], width, \n",
    "            label='Normal', color='#2196F3', alpha=0.8)\n",
    "    ax.barh(x - width/2, top_15['failure_mean_shap'], width, \n",
    "            label='Failure', color='#F44336', alpha=0.8)\n",
    "    \n",
    "    ax.set_yticks(x)\n",
    "    ax.set_yticklabels(top_15.index)\n",
    "    ax.invert_yaxis()\n",
    "    ax.set_xlabel('Mean |SHAP Value|')\n",
    "    ax.set_title(f'{model_name.replace(\"_\", \" \").title()} — Feature Importance: Normal vs Failure',\n",
    "                 fontsize=13, fontweight='bold')\n",
    "    ax.legend(fontsize=11)\n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Features with highest importance ratio (most differentially important in failures)\n",
    "for model_name, sr in shap_results.items():\n",
    "    comparison = sr['comparison']\n",
    "    \n",
    "    # Filter to features with meaningful baseline importance\n",
    "    meaningful = comparison[comparison['normal_mean_shap'] > comparison['normal_mean_shap'].median()]\n",
    "    top_ratio = meaningful.sort_values('importance_ratio', ascending=False).head(10)\n",
    "    \n",
    "    print(f'\\n{model_name} — Features Most Amplified in Failures:')\n",
    "    print(top_ratio[['normal_mean_shap', 'failure_mean_shap', 'importance_ratio']].to_string())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. SHAP Dependence Plots\n",
    "Show how individual feature values relate to SHAP impact."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Top 6 features dependence plots for Random Forest\n",
    "if 'random_forest' in shap_results:\n",
    "    sr = shap_results['random_forest']\n",
    "    feature_cols = results['feature_cols']\n",
    "    X_df = pd.DataFrame(sr['X_sample'], columns=feature_cols)\n",
    "    \n",
    "    top_features = sr['comparison'].head(6).index.tolist()\n",
    "    \n",
    "    fig, axes = plt.subplots(2, 3, figsize=(18, 10))\n",
    "    for feat, ax in zip(top_features, axes.flatten()):\n",
    "        feat_idx = feature_cols.index(feat)\n",
    "        shap.dependence_plot(feat_idx, sr['shap_values'], X_df,\n",
    "                            ax=ax, show=False, interaction_index=None)\n",
    "        ax.set_title(feat, fontsize=11)\n",
    "    \n",
    "    fig.suptitle('SHAP Dependence Plots — Top 6 Features (Random Forest)',\n",
    "                 fontsize=14, fontweight='bold')\n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Failure Case Deep Dive\n",
    "Examine individual high-error predictions to understand what went wrong."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Pick top 5 worst failure cases and show SHAP waterfall\n",
    "if 'random_forest' in shap_results:\n",
    "    sr = shap_results['random_forest']\n",
    "    errors_df = analysis['errors']['random_forest']\n",
    "    \n",
    "    # Get sampled failure indices\n",
    "    sampled_errors = errors_df.iloc[sr['indices']].copy()\n",
    "    sampled_errors['sample_idx'] = range(len(sampled_errors))\n",
    "    \n",
    "    worst_failures = sampled_errors.nlargest(5, 'abs_error')\n",
    "    \n",
    "    print('Top 5 Worst Prediction Failures (Random Forest):')\n",
    "    print(worst_failures[['zone_id', 'hour', 'day_of_week', 'y_true', 'y_pred', 'abs_error']].to_string())\n",
    "    \n",
    "    # SHAP force plot for worst failure\n",
    "    worst_idx = worst_failures['sample_idx'].iloc[0]\n",
    "    \n",
    "    print(f'\\nSHAP Waterfall for Worst Failure Case (Zone {worst_failures[\"zone_id\"].iloc[0]}, '\n",
    "          f'Hour {worst_failures[\"hour\"].iloc[0]}):')\n",
    "    print(f'  True: {worst_failures[\"y_true\"].iloc[0]:.0f}, '\n",
    "          f'Predicted: {worst_failures[\"y_pred\"].iloc[0]:.0f}, '\n",
    "          f'Error: {worst_failures[\"abs_error\"].iloc[0]:.0f}')\n",
    "    \n",
    "    explanation = shap.Explanation(\n",
    "        values=sr['shap_values'][worst_idx],\n",
    "        base_values=sr['explainer'].expected_value,\n",
    "        data=sr['X_sample'][worst_idx],\n",
    "        feature_names=results['feature_cols']\n",
    "    )\n",
    "    shap.plots.waterfall(explanation, show=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Linear Regression SHAP (Comparison)\n",
    "Compare feature drivers between Linear Regression and Random Forest."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if 'linear_regression' in shap_results:\n",
    "    sr_lr = shap_results['linear_regression']\n",
    "    X_df_lr = pd.DataFrame(sr_lr['X_sample'], columns=results['feature_cols'])\n",
    "    \n",
    "    print('Linear Regression - SHAP Summary:')\n",
    "    shap.summary_plot(sr_lr['shap_values'], X_df_lr, max_display=20, show=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare top features across models\n",
    "if len(shap_results) >= 2:\n",
    "    print('\\nTop 10 Features by Model (Failure Cases):')\n",
    "    print('=' * 60)\n",
    "    for model_name, sr in shap_results.items():\n",
    "        top_10 = sr['comparison'].head(10).index.tolist()\n",
    "        print(f'\\n{model_name}:')\n",
    "        for i, feat in enumerate(top_10, 1):\n",
    "            print(f'  {i}. {feat}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Key Explainability Findings\n",
    "\n",
   ]
  }
